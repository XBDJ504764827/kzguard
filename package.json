{
  "name": "kzguard",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "cargo run --manifest-path backend/Cargo.toml",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "cargo build --manifest-path backend/Cargo.toml",
    "check:backend": "cargo check --manifest-path backend/Cargo.toml",
    "start:backend": "cargo run --manifest-path backend/Cargo.toml --release",
    "build": "pnpm --filter frontend build && cargo build --manifest-path backend/Cargo.toml",
    "preview": "pnpm --filter frontend preview"
  }
}
